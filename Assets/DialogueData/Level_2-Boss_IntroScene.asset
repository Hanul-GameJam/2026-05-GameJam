  m_Script: {fileID: 11500000, guid: 7d3e8b49b61393344a956d20cc065de6, type: 3}
  m_Name: Level_2-Boss_IntroScene
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uBCF4\uAE30 \uC88B\uAC8C \uC81C \uBD80\uD558\uB4E4\uC744 \uC4F0\uB7EC\uB728\uB9AC\uBA70
      \uC624\uC168\uAD70\uC694\uC624.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC544\uBB34\uB9AC \uADF8\uB798\uB3C4 \uADF8\uB807\uC9C0, \uC624\uC9C1
      \uBA38\uB9AC \uBC1F\uAE30\uB9CC \uC774\uC6A9\uD574\uC11C \uC4F0\uB7EC\uB728\uB9AC\uB2E4\uB2C8\uC774...\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC124\uB9C8 \uB2F9\uC2E0, \uC2E4\uB825\uC774 \uB179\uC2AC\uAE30\uB77C\uB3C4
      \uD55C \uAC81\uB2C8\uAE4C\uC544?\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC544\uB2C8\uBA74, \uC774\uC815\uB3C4\uB294 \uBC1F\uAE30\uB9CC\uC73C\uB85C\uB3C4
      \uCDA9\uBD84\uD558\uB2E4\uB294...\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\"\uC624\uB9CC\"\uC77C\uAE4C?\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uB09C \uADF8\uC800 \uC740\uD1F4\uD558\uACE0 \uD3C9\uD654\uB86D\uAC8C
      \uC9D1\uC5D0\uC11C \uC26C\uACE0 \uC2F6\uB2E4\uACE0.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uBD88\uD544\uC694\uD55C \uC6C0\uC9C1\uC784\uC740 \uD558\uC9C0 \uC54A\uB294
      \uAC83\uC774 \uD3B8\uD558\uB2E4\uACE0 \uC0DD\uAC01\uD588\uC744 \uBFD0\uC774\uB2E4.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uADF8\uB807\uB2E4\uBA74, \uC800\uB97C \uC0C1\uB300\uD558\uBA74\uC11C\uB3C4
      \"\uD544\uC694\uD55C \uC6C0\uC9C1\uC784\"\uB9CC \uD560 \uC218 \uC788\uB294
      \uC9C0...\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uD55C \uBC88 \uBCF4\uC790\uACE0.\""
