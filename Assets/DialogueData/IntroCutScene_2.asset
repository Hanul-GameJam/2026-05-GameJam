%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7d3e8b49b61393344a956d20cc065de6, type: 3}
  m_Name: IntroCutScene_2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\uC5EC\uC5B4, \uC548\uB155\uD558\uC2ED\uB2C8\uAE4C\uC694\uC624.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uB10C \uB204\uAD6C\uC9C0? \uCC98\uC74C \uBCF4\uB294 \uC5BC\uAD74\uC778\uB370.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uB0A0 \uC54C\uACE0 \uC788\uB098?\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\uBB3C\uB860 \uC798 \uC54C\uACE0 \uC788\uC2B5\uC8E0\uC624.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\uC774 \uBC14\uB2E5\uC5D0\uC11C \uC81C\uC77C \uAC00\uB294,\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\uB9E1\uC740 \uC784\uBB34\uB77C\uBA74 100% \uC131\uACF5\uC744 \uBCF4\uC7A5\uD558\uB294,\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\"\uD574\uB2EC\uBCC4\" \uC870\uC9C1\uC758 \uBCF4\uC2A4\uC758 \uC624\uB978\uD314,\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\"\uCE7C\uB9BD\uC18C\" \uC528 \uC544\uB2C8\uC2ED\uB2C8\uAE4C\uC694\uC624.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uADF8\uB7FC \uB10C \uBB50\uD558\uB294 \uB140\uC11D\uC774\uAE38\uB798
      \uB098\uB97C \uCC3E\uC544\uC628 \uAC83\uC774\uC9C0?\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: ???
    dialogue: "\"\uC544\uC774\uCFE0, \uC2E4\uB840. \uC81C \uC18C\uAC1C\uAC00 \uB2A6\uC5C8\uAD70\uC694\uC624.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC81C \uC774\uB984\uC740 \"\uBBF8\uC2A4\uD2F0\", \"\uBE44\uBC84\uBC88\"\uC758
      \uAC04\uBD80 \uC911 \uD55C \uBA85\uC774\uB77C\uACE0 \uD574 \uB450\uC8E0\uC624.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\"\uBE44\uBC84\uBC88\"? \uCC98\uC74C \uB4E3\uB294 \uC870\uC9C1\uC778\uB370.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uADF8\uB7EC\uC2E4 \uC218\uB3C4 \uC788\uB2E4\uACE0 \uC0DD\uAC01\uD569\uB2C8\uB2E4\uC544.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC800\uD76C \uC870\uC9C1\uC740 \uC6D0\uB798 \uBD81\uC544\uBA54\uB9AC\uCE74\uC5D0\uC11C
      \uD65C\uB3D9\uD558\uACE0 \uC788\uC5C8\uB294\uB370,\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uCD5C\uADFC \uC601\uC5ED \uD655\uC7A5\uC744 \uD588\uC2B5\uC8E0\uC624.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC774 \uADFC\uCC98 \uAD6C\uC5ED\uC740 \"\uD574\uB2EC\uBCC4\"\uC774
      \uAD00\uB9AC\uD558\uB294 \uC601\uC5ED\uC778\uB370...\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uAC04\uB3C4 \uD06C\uAD70. \uC601\uC5ED \uCE68\uBC94\uC774\uB77C\uB2C8.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uBB50, \uADF8\uB807\uAC8C \uB9D0\uC500\uD558\uC154\uB3C4 \uD560
      \uB9D0\uC740 \uC5C6\uC2B5\uB2C8\uB2E4\uB9C8\uC548...\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uADF8\uB7FC \uAD00\uB9AC\uB97C \uC798 \uD588\uC5B4\uC57C\uC9C0.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uBB50?\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC544\uBB34\uD2BC, \uC911\uC694\uD55C \uAC74 \uC774\uAC8C \uC544\uB2C8\uB77C\uC544,\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC81C\uAC00 \uB2F9\uC2E0\uC744 \uCC3E\uC740 \uAC74, \uB2F9\uC2E0\uC744
      \uC6B0\uB9AC \"\uBE44\uBC84\uBC88\"\uC5D0 \uC601\uC785\uD558\uAE30 \uC704\uD574\uC11C\uC785\uB2C8\uB2E4\uC544.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uB09C \uAD00\uC2EC \uC5C6\uB2E4.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uC989\uB2F5\uC774\uB77C\uB2C8, \uC774\uAC83 \uCC38 \uB2F9\uD669\uC2A4\uB7FD\uAD70\uC694\uC624.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uADF8\uB798\uB3C4, \uB2E4\uC2DC \uD55C \uBC88\uB9CC \uB354 \uC0DD\uAC01\uC744...\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uB09C \uAC19\uC740 \uB9D0\uC740 \uB450 \uBC88 \uB2E4\uC2DC \uC548
      \uD55C\uB2E4.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC774\uC81C \uB0B4 \uC55E\uC5D0\uC11C \uC0AC\uB77C\uC838.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uD750\uC74C......\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uADF8\uB807\uB2E4\uBA74, \uB2E8\uCE7C\uC5D0 \uAC70\uC808\uD55C
      \uAC78 \uD6C4\uD68C\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC8FC\uB9C8.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uADF8\uB7FC, \uC804 \uC774\uB9CC \uAC00 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4\uC694\uC624.\""
  - portrait: {fileID: -1949824567, guid: 44f34ec5fdf5e2d4db503b1552ebac33, type: 3}
    characterName: "\uBBF8\uC2A4\uD2F0"
    dialogue: "\"\uB2E4\uC74C\uC5D0 \uB610 \uBD05\uC2DC\uB2E4\uC544.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: '"......"'
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uCC98\uC74C\uBD80\uD130 \uB05D\uAE4C\uC9C0 \uAE30\uBD84 \uB098\uC05C
      \uB140\uC11D\uC774\uC5C8\uC5B4.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC774\uC81C \uC9D1\uC5D0 \uB3CC\uC544\uAC00\uC11C \uC26C\uC5B4\uC57C...\""
  - portrait: {fileID: -4178046375966092550, guid: 52bd996089c80ca4890d4750c8b71a56, type: 3}
    characterName: ???
    dialogue: "\"\uC800\uAE30\uC788\uB2E4!\""
  - portrait: {fileID: -4178046375966092550, guid: 52bd996089c80ca4890d4750c8b71a56, type: 3}
    characterName: ???
    dialogue: "\"\uB140\uC11D\uC5D0\uAC8C \uD63C\uCB50\uC744 \uB0B4 \uC8FC\uC790!\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uCCC7... \uC5B4\uCA54 \uC218 \uC5C6\uB098?\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC2F8\uC6CC\uC11C \uBBF8\uC2A4\uD2F0 \uADF8 \uB140\uC11D\uC5D0\uAC8C
      \uD55C \uBC29 \uBA39\uC5EC\uC8FC\uB294 \uC218\uBC16\uC5D0...!\""
