  - portrait: {fileID: -4178046375966092550, guid: 52bd996089c80ca4890d4750c8b71a56, type: 3}
    characterName: "\uBE44\uBC84\uBC88 \uBD80\uD558 2"
    dialogue: "\"\uB10C \uBB34\uC870\uAC74 \uC81C\uC548\uC744 \uAC70\uC808\uD560
