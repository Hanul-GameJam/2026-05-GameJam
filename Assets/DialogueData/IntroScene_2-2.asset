  - portrait: {fileID: -4178046375966092550, guid: 52bd996089c80ca4890d4750c8b71a56, type: 3}
    characterName: "\uBE44\uBC84\uBC88 \uBD80\uD558 1"
    dialogue: "\"\uADF8\uB54C \uC6B0\uB9AC\uB294 \uAC70\uC808\uC758 \uB300\uAC00\uB97C
      \uCE58\uB8E8\uAC8C \uD558\uB294 \uAC70\uC9C0.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uCCC7... \uC5B4\uCA54 \uC218 \uC5C6\uB098?\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC2F8\uC6CC\uC11C \uBBF8\uC2A4\uD2F0 \uADF8 \uB140\uC11D\uC5D0\uAC8C
