  lines:
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uD06C\uC73D......\""
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uC544\uBB34\uB9AC \uC740\uD1F4\uD558\uC2E0\uB2E4\uC9C0\uB9CC, \uC5ED\uC2DC
      \uAC15\uD558\uC2DC\uAD70\uC694...\""
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uD55C \uAC00\uC9C0 \uC5EC\uCB59\uACE0 \uC2F6\uC740 \uAC8C \uC788\uC2B5\uB2C8\uB2E4...\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC74C? \uBB34\uC5C7\uC774\uC9C0?\""
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uC5B4\uC9F8\uC11C \uC800\uD76C\uB97C \uACF5\uACA9\uD558\uC2E0 \uAC81\uB2C8\uAE4C...?\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"...\uBB50\uB77C\uACE0?\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\"\uBCF4\uC2A4\"\uAED8\uC11C \uB108\uD76C\uAC00 \"\uC1A1\uBCC4\uD68C\"\uB97C
      \uC900\uBE44\uD55C\uB2E4\uACE0 \uD574\uC11C...\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"...\uADF8\uC5D0 \uB9DE\uAC8C \uB300\uC751\uD574 \uC92C\uB2E4\uB9CC...?\""
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uADF8\uAC8C \uBB34\uC2A8 \uC18C\uB9AC\uC2ED\uB2C8\uAE4C...\""
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uC800\uD770 \uC900\uBE44\uD574 \uB193\uC558\uB358 \"\uC1A1\uBCC4\uD68C
      \uD30C\uD2F0\"\uC5D0 \uCD08\uB300\uD558\uB824\uACE0 \uD588\uB2E8 \uB9D0\uC785\uB2C8\uB2E4...!\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uC544......\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: '"......"'
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: '"......"'
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: '"......"'
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uBBF8\uC548\uD558\uAC8C \uB410\uC5B4.\""
  - portrait: {fileID: -896319470, guid: 87e1789e24d60694e9228bf39aaf9a66, type: 3}
    characterName: "\uD2B8\uB808\uBAB0\uB85C"
    dialogue: "\"\uB410\uC2B5\uB2C8\uB2E4. \uD30C\uD2F0\uB294 \uBABB \uC5F4\uAC8C
      \uB410\uC9C0\uB9CC, \uC544\uBB34\uD2BC \uC870\uC2EC\uD788 \uC798 \uB4E4\uC5B4\uAC00\uC2ED\uC1FC.\""
  - portrait: {fileID: 665538603, guid: af9e5c4b2b97ff54c81361d029e7211e, type: 3}
    characterName: "\uB2F9\uC2E0"
    dialogue: "\"\uADF8\uB798, \uADF8\uB3D9\uC548 \uACE0\uB9C8\uC6E0\uB2E4.\""
